# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Moyasar (Payments)
MOYASAR_API_KEY=your-moyasar-api-key-here
MOYASAR_PUBLISHABLE_KEY=your-moyasar-publishable-key-here

# WhatsApp Business API
WHATSAPP_API_TOKEN=your-whatsapp-api-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ar
